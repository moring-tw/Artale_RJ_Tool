<Window x:Class="WpfFirebaseSync.GridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfFirebaseSync"
        Title="同步網格" Height="500" Width="300"
        Topmost="{Binding Source={x:Static local:AppConfig.Instance}, Path=IsTopmost}"
        Opacity="{Binding Source={x:Static local:AppConfig.Instance}, Path=WindowOpacity}"
        Closing="Window_Closing">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <!-- Y 軸標籤 (左) -->
            <ColumnDefinition Width="*"/>
            <!-- 按鈕網格 -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- 按鈕網格 -->
            <RowDefinition Height="30"/>
            <!-- X 軸標籤 (下) -->
        </Grid.RowDefinitions>

        <!-- 左側 Y 軸標籤 (10 到 1) -->
        <UniformGrid x:Name="YAxisGrid" Rows="10" Columns="1" Grid.Column="0" Grid.Row="0">
            <!-- 從程式碼動態生成 -->
        </UniformGrid>

        <!-- 主按鈕區域 (10 列 4 行) -->
        <UniformGrid x:Name="ButtonGrid" Rows="10" Columns="4" Grid.Column="1" Grid.Row="0">
            <!-- 從程式碼動態生成 -->
        </UniformGrid>

        <!-- 下方 X 軸標籤 (1 到 4) -->
        <UniformGrid Rows="1" Columns="4" Grid.Column="1" Grid.Row="1">
            <TextBlock Text="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="2" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="3" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </UniformGrid>
    </Grid>
</Window>
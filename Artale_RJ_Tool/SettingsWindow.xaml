<Window x:Class="WpfFirebaseSync.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfFirebaseSync"
        Title="設定" Height="280" Width="400" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15">

        <!-- 修改這裡：將標題與按鈕並排 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="Firebase 資料庫網址:" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="❓ 如何取得專屬網址？" Margin="15,0,0,0" Padding="5,2" Background="LightYellow" Click="OpenTutorial_Click"/>
        </StackPanel>

        <TextBox Text="{Binding Source={x:Static local:AppConfig.Instance}, Path=FirebaseUrl, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,0,0,15" Padding="5"/>

        <CheckBox Content="視窗永遠置頂 (TopMost)" 
                  IsChecked="{Binding Source={x:Static local:AppConfig.Instance}, Path=IsTopmost}" 
                  Margin="0,0,0,15" FontWeight="Bold"/>

        <TextBlock Text="主畫面透明度 (Opacity):" FontWeight="Bold" Margin="0,0,0,5"/>
        <Slider Minimum="0.2" Maximum="1.0" Value="{Binding Source={x:Static local:AppConfig.Instance}, Path=WindowOpacity}" 
                TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,0,0,15"/>

        <Button Content="關閉設定" Width="100" HorizontalAlignment="Right" Padding="5" Click="CloseButton_Click"/>
    </StackPanel>
</Window>